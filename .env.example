# Cron secret for Vercel Cron Jobs (e.g. cleanup-uploads). Set in Vercel env.
CRON_SECRET=

# Bearer secret for POST /canvas/upload (curate Iconify icons in canvas_studio_shapes).
CANVAS_STUDIO_UPLOAD_SECRET=

VITE_SUPABASE_URL=
VITE_SUPABASE_PUBLISHABLE_DEFAULT_KEY=
# Service role key (server-side only; for license activation and admin operations)
SUPABASE_SERVICE_ROLE_KEY=
# Set to "true" or "1" to show maintenance page instead of the app
VITE_MAINTENANCE_MODE=
# Comma-separated designer ids to hide (e.g. charm,flower)
VITE_UNDER_MAINTENANCE_DESIGNERS=
# Comma-separated designer ids to flag as "New" on the home screen (e.g. idNameTag,cakeTopper)
VITE_NEW_DESIGNERS=
# "Updated" badges are driven by UPDATE_NOTES in HomeScreen.svelte (no env var).
# Number of free downloads each signed-in user gets before the paywall.
VITE_FREE_TRIAL_CREDITS=
# Legacy exports before Supabase tracking (added to live DB total on the home counter).
VITE_EXPORT_STATS_BASE=1229

## Lemon Squeezy (subscriptions)
# Store and API config (used by checkout API route)
LEMONSQUEEZY_STORE_ID=
LEMONSQUEEZY_API_KEY=
# Webhook signing secret (also set as Supabase Edge Function secret)
LEMONSQUEEZY_WEBHOOK_SECRET=
# Subscription variants (IDs from Lemon Squeezy; also set as Edge Function secrets for webhook)
LEMONSQUEEZY_VARIANT_MONTHLY_ID=
LEMONSQUEEZY_VARIANT_YEARLY_ID=

# Feedback email notifications
RESEND_API_KEY=
FEEDBACK_NOTIFY_EMAIL=
# Optional: contact form only (defaults to FEEDBACK_NOTIFY_EMAIL)
CONTACT_NOTIFY_EMAIL=

# Telegram: export events (STL/3MF), contact form, in-app rating, visit pings (same bot/chat)
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=
# Local dev: Telegram is off unless set to true/1 (client + server must both be set).
VITE_ENABLE_DEV_TELEGRAM=
ENABLE_DEV_TELEGRAM=

# Optional: ipinfo.io token used to resolve country from IP when the platform
# doesn't provide a geo header (e.g. local dev). Sign up at https://ipinfo.io
# for a free token (50k req/mo). Unset = anonymous calls (lower rate limit).
IPINFO_TOKEN=

# PostHog project token
PUBLIC_POSTHOG_HOST=
PUBLIC_POSTHOG_PROJECT_TOKEN=
# Local dev: PostHog is off unless set to true/1 (client + server must both be set).
VITE_ENABLE_DEV_ANALYTICS=
ENABLE_DEV_ANALYTICS=

# Optional: external review URL (e.g. Trustpilot, App Store). If unset, "Leave a review" opens in-app Feedback.
PUBLIC_APP_REVIEW_URL=